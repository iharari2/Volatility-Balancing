# Volatility Balancing Backend Configuration

# Persistence Configuration
# Set to "sql" for persistent storage, "memory" for in-memory (default)
APP_PERSISTENCE=sql
APP_EVENTS=sql
APP_IDEMPOTENCY=memory

# Database Configuration
# SQLite is the correct default for local development - no setup required
SQL_URL=sqlite:///./vb.sqlite

# Production (Fly.io + Neon PostgreSQL) - set DATABASE_URL via fly secrets
# SQL_URL=postgresql://username:password@host/dbname?sslmode=require
#
# Local PostgreSQL (optional) - if you prefer postgres locally:
# SQL_URL=postgresql://postgres:yourpassword@localhost:5432/volatility_balancing

# Redis Configuration (optional, for idempotency)
# REDIS_URL=redis://localhost:6379/0

# Auto-create database tables on startup
APP_AUTO_CREATE=true

# Market Data Configuration
# YFinance is the default market data provider
MARKET_DATA_PROVIDER=yfinance

# Logging Configuration
LOG_LEVEL=INFO
